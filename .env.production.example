# Corporate Control Tower production environment template.
# Copy to .env.production on the server and replace all secret values.

CONTROL_TOWER_IMAGE=corporate-control-tower-rev12:prod
CONTROL_TOWER_BIND=127.0.0.1
CONTROL_TOWER_PORT=8000

POSTGRES_DB=controltower
POSTGRES_USER=controltower
POSTGRES_PASSWORD=change-me
CONTROL_TOWER_DATABASE_URL=postgresql+psycopg://controltower:change-me@postgis:5432/controltower

CONTROL_TOWER_NAS_ROOT=/mnt/nas
CONTROL_TOWER_NAS_HOST_PATH=/srv/bimsig/nas
CONTROL_TOWER_REPORT_OUTPUT_DIR=/app/output/pdf

CONTROL_TOWER_RUN_MIGRATIONS=true
CONTROL_TOWER_WAIT_FOR_DB=true
CONTROL_TOWER_DB_WAIT_SECONDS=90

CONTROL_TOWER_AUTH_REQUIRED=true
CONTROL_TOWER_AUTH_SECRET=replace-with-strong-random-secret
CONTROL_TOWER_AUTH_TTL_MINUTES=480

CONTROL_TOWER_GEOSERVER_URL=https://geoserver.example.com/geoserver
CONTROL_TOWER_GEOSERVER_USER=replace-me
CONTROL_TOWER_GEOSERVER_PASSWORD=replace-me

CONTROL_TOWER_GOOGLE_DRIVE_ROOT_ID=replace-me
CONTROL_TOWER_GOOGLE_APPLICATION_CREDENTIALS=/run/secrets/google-workspace.json

HTTP_PORT=80
HTTPS_PORT=443
CONTROL_TOWER_TLS_CERTS_PATH=/srv/bimsig/tls
